# LLM 配置 (OpenAI 兼容协议)
# 支持 Qwen DashScope / Deepseek / OpenAI / 本地 vLLM
LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen2.5-7b-instruct

# 主决策模型(可选,默认同 LLM_MODEL)
ROUTER_MODEL=

# Embedding 模型 (本地 sentence-transformers,无需 API)
EMBEDDING_MODEL=BAAI/bge-m3

# Redis (可选,不配置则用内存缓存)
REDIS_URL=

# 向量库: chroma | milvus
VECTOR_STORE=chroma
MILVUS_URI=

# 图存储: networkx | neo4j
GRAPH_STORE=networkx
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=
